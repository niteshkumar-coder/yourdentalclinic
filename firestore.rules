rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /appointments/{appointmentId} {
      // Allow creation for all users (for booking)
      allow create: if true;
      
      // Admin operations - In this specific password-based flow, we allow these
      // but warn that this should be hardened for a production environment.
      allow read, update, delete: if true; 
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "niteshkumar9128ku@gmail.com");
    }
  }
}
